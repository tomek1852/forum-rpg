generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  GM
  ADMIN
}

enum AccountStatus {
  PENDING_APPROVAL
  ACTIVE
  BLOCKED
}

enum NotificationType {
  FORUM_NEW_THREAD
  FORUM_THREAD_REPLY
  FORUM_POST_QUOTE
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  username            String               @unique
  passwordHash        String
  role                UserRole             @default(PLAYER)
  status              AccountStatus        @default(ACTIVE)
  isActive            Boolean              @default(true)
  emailVerified       Boolean              @default(false)
  displayName         String?
  bio                 String?
  avatarUrl           String?
  lastSeenAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  characters          Character[]
  forumThreads        ForumThread[]        @relation("ForumThreadAuthor")
  forumPosts          ForumPost[]          @relation("ForumPostAuthor")
  notifications       Notification[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Character {
  id          String   @id @default(uuid())
  name        String
  title       String?
  summary     String?
  biography   String?
  appearance  String?
  avatarUrl   String?
  statsJson   Json?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model ForumCategory {
  id          String       @id @default(uuid())
  title       String
  description String?
  color       String?
  position    Int          @default(0)
  isArchived  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  threads     ForumThread[]
}

model ForumThread {
  id         String        @id @default(uuid())
  title      String
  isPinned   Boolean       @default(false)
  isLocked   Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  lastPostAt DateTime      @default(now())
  categoryId String
  authorId   String
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author     User          @relation("ForumThreadAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  posts      ForumPost[]

  @@index([categoryId, lastPostAt])
  @@index([authorId])
}

model ForumPost {
  id          String      @id @default(uuid())
  content     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  editedAt    DateTime?
  threadId    String
  authorId    String
  quotePostId String?
  thread      ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author      User        @relation("ForumPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  quotePost   ForumPost?  @relation("ForumPostQuote", fields: [quotePostId], references: [id], onDelete: SetNull)
  quotedIn    ForumPost[] @relation("ForumPostQuote")

  @@index([threadId, createdAt])
  @@index([authorId])
  @@index([quotePostId])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}
