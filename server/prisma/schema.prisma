generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  GM
  ADMIN
}

enum AccountStatus {
  PENDING_APPROVAL
  ACTIVE
  BLOCKED
}

enum NotificationType {
  FORUM_NEW_THREAD
  FORUM_THREAD_REPLY
  FORUM_POST_QUOTE
  SKILL_PROPOSAL_CREATED
  SKILL_PROPOSAL_APPROVED
  SKILL_PROPOSAL_REJECTED
}

enum StatValueType {
  NUMBER
  TEXT
}

enum SkillProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventParticipationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  username            String               @unique
  passwordHash        String
  role                UserRole             @default(PLAYER)
  status              AccountStatus        @default(ACTIVE)
  isActive            Boolean              @default(true)
  emailVerified       Boolean              @default(false)
  displayName         String?
  bio                 String?
  avatarUrl           String?
  lastSeenAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  characters          Character[]
  forumThreads        ForumThread[]        @relation("ForumThreadAuthor")
  forumPosts          ForumPost[]          @relation("ForumPostAuthor")
  notifications       Notification[]
  conversationsStarted Conversation[]      @relation("ConversationUserOne")
  conversationsReceived Conversation[]     @relation("ConversationUserTwo")
  privateMessagesSent PrivateMessage[]     @relation("PrivateMessageSender")
  createdSkillProposals SkillProposal[]    @relation("SkillProposalAuthor")
  reviewedSkillProposals SkillProposal[]   @relation("SkillProposalReviewer")
  grantedCharacterSkills CharacterSkill[]  @relation("CharacterSkillReviewer")
  grantedProgressEntries ProgressEntry[]   @relation("ProgressEntryGrantor")
  createdEvents       Event[]              @relation("EventCreator")
  reviewedEventParticipations EventParticipation[] @relation("EventParticipationReviewer")
}

model World {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  summary         String?
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  characters      Character[]
  statDefinitions StatDefinition[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Character {
  id          String   @id @default(uuid())
  name        String
  title       String?
  summary     String?
  biography   String?
  appearance  String?
  avatarUrl   String?
  statsJson   Json?
  experiencePoints Int @default(0)
  heroPoints  Int @default(0)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String
  worldId     String?
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  world       World?   @relation(fields: [worldId], references: [id], onDelete: SetNull)
  statValues  CharacterStatValue[]
  skillProposals SkillProposal[]
  skills      CharacterSkill[]
  progressEntries ProgressEntry[]
  eventParticipations EventParticipation[]

  @@index([ownerId])
  @@index([worldId])
}

model ProgressRule {
  id          String          @id @default(uuid())
  code        String          @unique
  label       String
  description String?
  expValue    Int             @default(0)
  phValue     Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  entries     ProgressEntry[]
}

model ProgressEntry {
  id          String        @id @default(uuid())
  expDelta    Int           @default(0)
  phDelta     Int           @default(0)
  reason      String
  note        String?
  createdAt   DateTime      @default(now())
  characterId String
  grantedById String?
  ruleId      String?
  character   Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  grantedBy   User?         @relation("ProgressEntryGrantor", fields: [grantedById], references: [id], onDelete: SetNull)
  rule        ProgressRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([characterId, createdAt])
  @@index([grantedById])
  @@index([ruleId])
}

model SkillProposal {
  id             String              @id @default(uuid())
  name           String
  description    String
  mechanics      String?
  costs          String?
  limitations    String?
  status         SkillProposalStatus @default(PENDING)
  reviewerComment String?
  reviewedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  characterId    String
  proposerId     String
  reviewerId     String?
  character      Character           @relation(fields: [characterId], references: [id], onDelete: Cascade)
  proposer       User                @relation("SkillProposalAuthor", fields: [proposerId], references: [id], onDelete: Cascade)
  reviewer       User?               @relation("SkillProposalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  createdSkill   CharacterSkill?

  @@index([characterId, status, createdAt])
  @@index([proposerId, status, createdAt])
  @@index([reviewerId])
}

model CharacterSkill {
  id             String        @id @default(uuid())
  name           String
  description    String
  mechanics      String?
  costs          String?
  limitations    String?
  grantedAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  characterId    String
  approvedById   String?
  sourceProposalId String?     @unique
  character      Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  approvedBy     User?         @relation("CharacterSkillReviewer", fields: [approvedById], references: [id], onDelete: SetNull)
  sourceProposal SkillProposal? @relation(fields: [sourceProposalId], references: [id], onDelete: SetNull)

  @@index([characterId, grantedAt])
  @@index([approvedById])
}

model Event {
  id              String               @id @default(uuid())
  title           String
  summary         String?
  description     String?
  location        String?
  startsAt        DateTime
  endsAt          DateTime?
  maxParticipants Int?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  creatorId       String
  creator         User                 @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participations  EventParticipation[]

  @@index([startsAt])
  @@index([creatorId, createdAt])
}

model EventParticipation {
  id              String                   @id @default(uuid())
  status          EventParticipationStatus @default(PENDING)
  note            String?
  reviewerComment String?
  decidedAt       DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  eventId         String
  characterId     String
  reviewerId      String?
  event           Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  character       Character                @relation(fields: [characterId], references: [id], onDelete: Cascade)
  reviewer        User?                    @relation("EventParticipationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@unique([eventId, characterId])
  @@index([eventId, status, createdAt])
  @@index([characterId, status, createdAt])
  @@index([reviewerId])
}

model StatDefinition {
  id                  String               @id @default(uuid())
  key                 String
  label               String
  description         String?
  valueType           StatValueType        @default(NUMBER)
  minValue            Int?
  maxValue            Int?
  defaultNumericValue Int?
  defaultTextValue    String?
  isRequired          Boolean              @default(false)
  isActive            Boolean              @default(true)
  position            Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  worldId             String
  world               World                @relation(fields: [worldId], references: [id], onDelete: Cascade)
  characterValues     CharacterStatValue[]

  @@unique([worldId, key])
  @@index([worldId, position])
}

model CharacterStatValue {
  id               String         @id @default(uuid())
  numericValue     Int?
  textValue        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  characterId      String
  statDefinitionId String
  character        Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)
  statDefinition   StatDefinition @relation(fields: [statDefinitionId], references: [id], onDelete: Cascade)

  @@unique([characterId, statDefinitionId])
  @@index([characterId])
  @@index([statDefinitionId])
}

model ForumCategory {
  id          String       @id @default(uuid())
  title       String
  description String?
  color       String?
  position    Int          @default(0)
  isArchived  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  threads     ForumThread[]
}

model ForumThread {
  id         String        @id @default(uuid())
  title      String
  isPinned   Boolean       @default(false)
  isLocked   Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  lastPostAt DateTime      @default(now())
  categoryId String
  authorId   String
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author     User          @relation("ForumThreadAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  posts      ForumPost[]

  @@index([categoryId, lastPostAt])
  @@index([authorId])
}

model ForumPost {
  id          String      @id @default(uuid())
  content     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  editedAt    DateTime?
  threadId    String
  authorId    String
  quotePostId String?
  thread      ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author      User        @relation("ForumPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  quotePost   ForumPost?  @relation("ForumPostQuote", fields: [quotePostId], references: [id], onDelete: SetNull)
  quotedIn    ForumPost[] @relation("ForumPostQuote")

  @@index([threadId, createdAt])
  @@index([authorId])
  @@index([quotePostId])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model Conversation {
  id            String           @id @default(uuid())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  lastMessageAt DateTime         @default(now())
  userOneId     String
  userTwoId     String
  userOne       User             @relation("ConversationUserOne", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo       User             @relation("ConversationUserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)
  messages      PrivateMessage[]

  @@unique([userOneId, userTwoId])
  @@index([userOneId, lastMessageAt])
  @@index([userTwoId, lastMessageAt])
}

model PrivateMessage {
  id             String       @id @default(uuid())
  content        String
  createdAt      DateTime     @default(now())
  readAt         DateTime?
  conversationId String
  senderId       String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("PrivateMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
  @@index([senderId, createdAt])
}
